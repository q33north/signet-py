ANTHROPIC_API_KEY=
DISCORD_TOKEN=
DISCORD_APPLICATION_ID=

DATABASE_URL=postgresql://signet:signet@localhost:5432/signet
EMBEDDING_MODEL=all-MiniLM-L6-v2
MEMORY_RECALL_LIMIT=5

# Nightshift autonomous research (optional)
# NIGHTSHIFT_ENABLED=true
# NIGHTSHIFT_CHANNEL_ID=your-channel-id

# autoDream scheduler (optional)
# DREAM_ENABLED=true
# DREAM_INTERVAL_MINUTES=720        # every 12 hours
# DREAM_MIN_MESSAGES=20             # skip runs below this threshold
# DREAM_CHANNEL_ID=                 # admin channel for dream receipts (optional)

# Wiki location (optional, defaults to ./wikis/)
# WIKIS_PATH=/path/to/your/wiki/directory
